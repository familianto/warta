---
import Base from "../layouts/Base.astro";
import { getArticleList } from "../lib/articles";

const articles = getArticleList();

function formatDate(iso: string): string {
  const date = new Date(iso);
  return date.toLocaleDateString("id-ID", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
}
---

<Base title="Warta">
  <div class="container">
    <main class="main">
      <p class="tagline">Catatan dan tulisan seputar teknologi, pengembangan web, dan produktivitas.</p>

      <div class="mindmap-cta">
        <span class="mindmap-cta-text">Lihat bagaimana artikel-artikel ini saling terhubung</span>
        <a href={`${import.meta.env.BASE_URL}peta/`} class="mindmap-cta-link">Peta Pikiran &rarr;</a>
      </div>

      <div class="article-list">
        {articles.map((article) => (
          <article class="article-card">
            <div class="article-body">
              <a href={`${import.meta.env.BASE_URL}artikel/${article.slug}/`} class="article-title-link">
                <h2 class="article-title">{article.title}</h2>
              </a>
              {article.subtitle && <p class="article-subtitle">{article.subtitle}</p>}
              <div class="article-meta">
                <time datetime={article.createdAt}>{formatDate(article.createdAt)}</time>
                <div class="article-tags">
                  {article.tags.map((tag) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </main>
  </div>
</Base>

<style>
  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem 3rem;
  }

  .tagline {
    font-size: 1.1rem;
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin-bottom: 2.5rem;
  }

  .mindmap-cta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    margin-bottom: 2rem;
    font-size: 0.9rem;
  }

  .mindmap-cta-text {
    color: var(--color-text-secondary);
  }

  .mindmap-cta-link {
    color: var(--color-primary);
    font-weight: 500;
    white-space: nowrap;
  }

  .article-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .article-card {
    display: flex;
    gap: 1.5rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .article-card:first-child {
    padding-top: 0;
  }

  .article-body {
    flex: 1;
    min-width: 0;
  }

  .article-title-link {
    color: var(--color-text);
    text-decoration: none;
  }

  .article-title-link:hover {
    text-decoration: none;
  }

  .article-title {
    font-size: 1.35rem;
    font-weight: 700;
    line-height: 1.4;
    margin-bottom: 0.4rem;
    transition: color 0.15s ease;
  }

  .article-title-link:hover .article-title {
    color: var(--color-primary);
  }

  .article-subtitle {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .article-meta time {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }

  .article-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.75rem;
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
    background-color: var(--color-surface);
    color: var(--color-text-secondary);
    font-weight: 500;
  }

  @media (max-width: 480px) {
    .container {
      padding: 0 1rem 2rem;
    }

    .article-title {
      font-size: 1.15rem;
    }

    .mindmap-cta {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
    }
  }
</style>
