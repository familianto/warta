---
import Base from "../layouts/Base.astro";
---

<Base title="Peta Pikiran — Warta">
  <div class="container">
    <main class="main">
      <h1>Peta Pikiran</h1>
      <p class="coming-soon">Coming soon</p>
    </main>
  </div>
</Base>

<style>
  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  h1 {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .coming-soon {
    color: var(--color-text-secondary);
    font-size: 1.1rem;
  }
</style>
